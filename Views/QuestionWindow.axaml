<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="150" Width="400" Height="150"
        x:Class="DialogueHelper.Views.QuestionWindow"
        Title="Question Window">
    <Panel Margin="5">
        <TextBlock TextWrapping="Wrap" Name="InnerText">Are you sure you want to do Action?</TextBlock>
        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Name="YesButton" Click="YesButton_OnClick">Yes</Button>
            <Button Name="NoButton" Click="NoButton_OnClick">No</Button>
        </StackPanel>
    </Panel>
</Window>
