<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="180" CanResize="False" Width="400" Height="180"
        x:Class="DialogueHelper.Views.CreateEntry"
        Title="Create Entry">
    <Panel Margin="5">
        <StackPanel Orientation="Vertical" Spacing="7">
            <TextBlock Name="EntryText">Set the entry content</TextBlock>
            <TextBox Name="TextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="100"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Name="FinishButton" Click="FinishButton_OnClick">Finish</Button>
            <Button Name="CancelButton" Click="CancelButton_OnClick">Cancel</Button>
        </StackPanel>
    </Panel>
</Window>
